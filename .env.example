# Local configuration example for OHLCV-20-TICKERS-B3.
# The script reads environment variables directly.

PRICES_B3_DB_PATH=prices_b3.db

# Optional PostgreSQL configuration for private local scripts outside the tracked repo.
# Never commit real credentials.
PGHOST=localhost
PGPORT=5432
PGDATABASE=prices_b3
PGUSER=postgres
PGPASSWORD=change-me
